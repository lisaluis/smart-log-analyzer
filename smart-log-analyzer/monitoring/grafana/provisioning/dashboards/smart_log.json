{
  "title": "Smart Log Analyzer",
  "uid": "smart-log-analyzer",
  "schemaVersion": 27,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total Predictions",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "prediction_requests_total", "legendFormat": "Requests"}]
    },
    {
      "id": 2, "type": "stat", "title": "Total Failures Detected",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "failure_predictions_total", "legendFormat": "Failures"}]
    },
    {
      "id": 3, "type": "graph", "title": "Prediction Rate (per min)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "rate(prediction_requests_total[1m])", "legendFormat": "Requests/min"}]
    },
    {
      "id": 4, "type": "graph", "title": "Avg Response Latency (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{
        "expr": "rate(prediction_latency_seconds_sum[5m]) / rate(prediction_latency_seconds_count[5m]) * 1000",
        "legendFormat": "Latency ms"
      }]
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s"
}
